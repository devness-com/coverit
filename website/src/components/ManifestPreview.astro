---
const manifest = {
  projectName: "my-api",
  score: 82,
  dimensions: {
    functionality: { score: 88, gaps: 3 },
    security:      { score: 95, gaps: 0 },
    stability:     { score: 74, gaps: 7 },
    conformance:   { score: 65, gaps: 5 },
    regression:    { score: 92, gaps: 1 }
  },
  modules: [ "src/auth", "src/booking", "src/payments" ],
  journeys: [ "user-signup", "payment-flow" ]
};
---

<div class="manifest-preview paper-card rounded-2xl p-8 max-w-lg mx-auto overflow-hidden animate-on-scroll">
  <div class="flex items-center justify-between mb-8 border-b border-border-strong/10 pb-4">
     <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-lg bg-amber/10 text-amber flex items-center justify-center">
           <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        </div>
        <span class="font-heading font-black text-sm text-text uppercase tracking-widest">coverit.json</span>
     </div>
     <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
        <span class="font-mono text-[10px] text-text-muted/60 font-bold uppercase tracking-widest">Live Sync</span>
     </div>
  </div>

  <div class="font-mono text-[13px] leading-relaxed relative group/manifest">
    <div class="text-text-muted/40 absolute -left-6 h-full border-l border-dashed border-border-strong/20"></div>
    
    <div class="pl-2 space-y-1">
      <div class="flex gap-2">
         <span class="text-amber/60">"projectName"</span>: 
         <span class="text-accent font-semibold">"my-api"</span>,
      </div>
      <div class="flex gap-2 group/score cursor-help hover:bg-accent/5 -mx-2 px-2 py-0.5 rounded transition-colors">
         <span class="text-amber/60">"score"</span>: 
         <span class="text-accent font-black">{manifest.score}</span>,
         <div class="absolute right-0 top-0 opacity-0 group-hover/score:opacity-100 transition-opacity bg-accent text-white font-heading font-bold px-3 py-1 rounded-full text-[10px] -translate-y-full mb-2">Confidence Level: High</div>
      </div>
      
      <div class="mt-4">
         <span class="text-amber/60">"dimensions"</span>: {"{"}
         <div class="pl-6 space-y-1 border-l border-border-strong/10 my-2 ml-2">
            {Object.entries(manifest.dimensions).map(([key, value]) => (
               <div class="flex gap-2 group/dim cursor-help hover:bg-amber/5 -mx-2 px-2 py-0.5 rounded transition-colors relative">
                  <span class="text-text/70">"{key}"</span>: {"{"} 
                  <span class="text-amber-dim">"score"</span>: {value.score}, 
                  <span class="text-amber-dim">"gaps"</span>: {value.gaps} 
                  {"}"},
                  
                  <!-- Preview overlay -->
                  <div class="absolute left-full ml-4 top-1/2 -translate-y-1/2 w-48 p-3 rounded-lg bg-bg-warm border border-border shadow-editorial opacity-0 translate-x-4 pointer-events-none group-hover/dim:opacity-100 group-hover/dim:translate-x-0 transition-all z-20">
                     <p class="font-heading font-black text-[10px] uppercase text-accent mb-1">{key} Analysis</p>
                     <div class="h-1 bg-border rounded-full overflow-hidden mb-2">
                        <div class="h-full bg-accent" style={`width: ${value.score}%;`}></div>
                     </div>
                     <p class="font-body text-[10px] text-text-muted leading-tight">{value.gaps} gaps remaining in this dimension.</p>
                  </div>
               </div>
            ))}
         </div>
         {"}"},
      </div>
      
      <div class="mt-4 flex gap-2">
         <span class="text-amber/60">"modules"</span>: 
         <span class="text-text/50">[ ... ]</span>,
      </div>
      <div class="flex gap-2">
         <span class="text-amber/60">"journeys"</span>: 
         <span class="text-text/50">[ ... ]</span>
      </div>
    </div>
  </div>

  <p class="font-body text-xs text-text-muted mt-8 text-center px-4 italic leading-relaxed">
    "The single, git-tracked source of truth for your test quality."
  </p>
</div>