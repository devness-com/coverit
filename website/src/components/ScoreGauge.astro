---
interface Props {
  score?: number;
  size?: number;
  interactive?: boolean;
}

const { score = 82, size = 200, interactive = true } = Astro.props;

const radius = 80;
const strokeWidth = 10;
const circumference = 2 * Math.PI * radius;
const offset = circumference - (score / 100) * circumference;
const viewBox = `0 0 ${size} ${size}`;
const center = size / 2;
---

<div class:list={["score-gauge flex flex-col items-center gap-4 transition-transform duration-500", interactive && "hover:scale-105"]}>
  <div class="gauge-wrapper relative group cursor-default" style={`width: ${size}px; height: ${size}px;`}>
    <svg
      viewBox={viewBox}
      width={size}
      height={size}
      class="gauge-svg drop-shadow-editorial"
      role="img"
      aria-label={`Quality score: ${score} out of 100`}
    >
      <!-- Background ring -->
      <circle
        cx={center}
        cy={center}
        r={radius}
        fill="none"
        stroke="var(--color-border)"
        stroke-width={strokeWidth}
        class="opacity-50"
      />
      <!-- Filled arc -->
      <circle
        cx={center}
        cy={center}
        r={radius}
        fill="none"
        stroke="var(--color-accent)"
        stroke-width={strokeWidth}
        stroke-linecap="round"
        stroke-dasharray={circumference}
        stroke-dashoffset={circumference}
        class="gauge-arc transition-all duration-1000 ease-out"
        transform={`rotate(-90 ${center} ${center})`}
        style={`--gauge-target: ${offset};`}
      />
    </svg>
    <!-- Score number overlay -->
    <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none">
      <div class="flex items-baseline gap-0.5">
        <span
          class="gauge-number font-heading font-black text-5xl text-accent leading-none"
          data-target={score}
        >
          0
        </span>
        <span class="font-body text-sm font-semibold text-text-muted">%</span>
      </div>
      <span class="font-body text-[10px] text-text-muted uppercase tracking-[0.2em] mt-2 opacity-60">Confidence</span>
    </div>

    <!-- Interactive hover pulse -->
    <div class="absolute inset-0 rounded-full border-2 border-accent/0 group-hover:border-accent/20 group-hover:scale-110 transition-all duration-700 pointer-events-none"></div>
  </div>
  
  <div class="flex flex-col items-center">
    <span class="text-[11px] font-heading font-bold text-text-muted uppercase tracking-[0.2em] mb-1">Quality Score</span>
    <div class="h-0.5 w-8 bg-amber/30 rounded-full"></div>
  </div>
</div>

<style>
  .gauge-wrapper {
    filter: drop-shadow(0 0 30px rgba(196, 98, 58, 0.08));
  }

  .gauge-arc {
    stroke-dashoffset: circumference; /* Start at full circumference */
    animation: gauge-fill 1.8s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s forwards;
  }

  @keyframes gauge-fill {
    to {
      stroke-dashoffset: var(--gauge-target);
    }
  }

  /* Pulse animation for 'scanning' state */
  .is-scanning .gauge-arc {
    animation: gauge-pulse 2s ease-in-out infinite;
    stroke-dashoffset: 0;
    opacity: 0.6;
  }

  @keyframes gauge-pulse {
    0%, 100% { transform: rotate(-90deg) scale(1); }
    50% { transform: rotate(-90deg) scale(1.02); }
  }

  @media (prefers-reduced-motion: reduce) {
    .gauge-arc {
      animation: none;
      stroke-dashoffset: var(--gauge-target);
    }
  }
</style>

<script>
  class ScoreGaugeController {
    el: HTMLElement;
    numberEl: HTMLElement;
    arcEl: SVGElement;
    targetScore: number;

    constructor(el: HTMLElement) {
      this.el = el;
      this.numberEl = el.querySelector('.gauge-number') as HTMLElement;
      this.arcEl = el.querySelector('.gauge-arc') as SVGElement;
      this.targetScore = parseInt(this.numberEl.dataset.target || '0', 10);
      
      this.init();
      
      // Listen for global re-scan events
      window.addEventListener('coverit:rescan', (e: any) => {
        this.animateTo(e.detail?.score ?? this.targetScore);
      });
    }

    init() {
      this.animateTo(this.targetScore);
    }

    animateTo(score: number) {
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      
      if (prefersReducedMotion) {
        this.numberEl.textContent = String(score);
        return;
      }

      const duration = 2000;
      const startValue = parseInt(this.numberEl.textContent || '0', 10);
      const startTime = performance.now();

      const tick = (now: number) => {
        const elapsed = now - startTime;
        const progress = Math.min(elapsed / duration, 1);
        
        // Elastic out easing
        const eased = 1 - Math.pow(1 - progress, 4);
        
        const current = Math.round(startValue + (score - startValue) * eased);
        this.numberEl.textContent = String(current);

        if (progress < 1) {
          requestAnimationFrame(tick);
        }
      };

      requestAnimationFrame(tick);
    }
  }

  document.querySelectorAll<HTMLElement>('.score-gauge').forEach(el => {
    new ScoreGaugeController(el);
  });
</script>
