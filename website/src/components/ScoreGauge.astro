---
interface Props {
  score?: number;
  size?: number;
}

const { score = 82, size = 120 } = Astro.props;

const strokeWidth = 6;
const radius = (size / 2) - strokeWidth;
const circumference = 2 * Math.PI * radius;
const offset = circumference - (score / 100) * circumference;
const center = size / 2;
---

<div class="score-gauge relative" style={`width: ${size}px; height: ${size}px;`}>
  <svg
    viewBox={`0 0 ${size} ${size}`}
    width={size}
    height={size}
    class="gauge-svg"
    role="img"
    aria-label={`Quality score: ${score} out of 100`}
  >
    <!-- White filled background circle -->
    <circle
      cx={center}
      cy={center}
      r={size / 2 - 1}
      fill="var(--color-bg-warm)"
      stroke="var(--color-border)"
      stroke-width="1"
    />
    <!-- Track ring -->
    <circle
      cx={center}
      cy={center}
      r={radius}
      fill="none"
      stroke="var(--color-border)"
      stroke-width={strokeWidth}
      class="opacity-30"
    />
    <!-- Progress arc -->
    <circle
      cx={center}
      cy={center}
      r={radius}
      fill="none"
      stroke="var(--color-accent)"
      stroke-width={strokeWidth}
      stroke-linecap="round"
      stroke-dasharray={circumference}
      stroke-dashoffset={circumference}
      class="gauge-arc"
      transform={`rotate(-90 ${center} ${center})`}
      style={`--gauge-target: ${offset};`}
    />
  </svg>

  <!-- Score content overlay -->
  <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none">
    <div class="flex items-baseline">
      <span
        class="gauge-number font-heading font-black text-[2rem] text-accent leading-none"
        data-target={score}
      >
        0
      </span>
      <span class="font-heading text-xs font-bold text-text-muted/60">%</span>
    </div>
    <span class="font-heading text-[7px] font-bold text-text-muted uppercase tracking-[0.15em] mt-1 opacity-50">Quality Score</span>
  </div>
</div>

<style>
  .score-gauge {
    filter: drop-shadow(0 4px 16px rgba(44, 36, 24, 0.12));
  }

  .gauge-arc {
    animation: gauge-fill 1.8s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s forwards;
  }

  @keyframes gauge-fill {
    to {
      stroke-dashoffset: var(--gauge-target);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gauge-arc {
      animation: none;
      stroke-dashoffset: var(--gauge-target);
    }
  }
</style>

<script>
  class ScoreGaugeController {
    el: HTMLElement;
    numberEl: HTMLElement;
    arcEl: SVGCircleElement;
    circumference: number;

    constructor(el: HTMLElement) {
      this.el = el;
      this.numberEl = el.querySelector('.gauge-number') as HTMLElement;
      this.arcEl = el.querySelector('.gauge-arc') as SVGCircleElement;
      this.circumference = parseFloat(this.arcEl.getAttribute('stroke-dasharray') || '0');

      const target = parseInt(this.numberEl.dataset.target || '0', 10);
      this.animateTo(target);

      window.addEventListener('coverit:rescan', (e: any) => {
        this.animateTo(e.detail?.score ?? target);
      });
    }

    animateTo(score: number) {
      // Update arc
      const offset = this.circumference - (score / 100) * this.circumference;
      this.arcEl.style.strokeDashoffset = String(offset);
      this.arcEl.style.transition = 'stroke-dashoffset 1.8s cubic-bezier(0.34, 1.56, 0.64, 1)';

      // Update number
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        this.numberEl.textContent = String(score);
        return;
      }

      const duration = 2000;
      const startValue = parseInt(this.numberEl.textContent || '0', 10);
      const startTime = performance.now();

      const tick = (now: number) => {
        const elapsed = now - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 4);
        this.numberEl.textContent = String(Math.round(startValue + (score - startValue) * eased));
        if (progress < 1) requestAnimationFrame(tick);
      };

      requestAnimationFrame(tick);
    }
  }

  document.querySelectorAll<HTMLElement>('.score-gauge').forEach(el => {
    new ScoreGaugeController(el);
  });
</script>
