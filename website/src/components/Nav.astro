---
const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/docs', label: 'Docs' },
  { href: '/changelog', label: 'Changelog' },
  { href: '/about', label: 'About' },
];

function isActive(href: string): boolean {
  return pathname === href || pathname.startsWith(href + '/');
}
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-bg/90 backdrop-blur-md border-b border-border">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="font-heading font-bold text-3xl hover:opacity-80 transition-opacity">
      <span class="text-text">cover</span><span class="text-accent">it</span>
    </a>

    <!-- Desktop navigation -->
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'text-sm font-body transition-colors relative pb-0.5',
            isActive(link.href)
              ? 'text-text border-b-2 border-accent'
              : 'text-text-muted hover:text-text',
          ]}
        >
          {link.label}
        </a>
      ))}

      <!-- GitHub icon -->
      <a
        href="https://github.com/devness-com/coverit"
        target="_blank"
        rel="noopener noreferrer"
        class="text-text-muted hover:text-text transition-colors"
        aria-label="GitHub repository"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
        </svg>
      </a>
    </div>

    <!-- Mobile hamburger (CSS-only) -->
    <label for="nav-toggle" class="md:hidden cursor-pointer text-text-muted hover:text-text transition-colors" aria-label="Toggle navigation menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </label>
  </div>

  <!-- Mobile menu (CSS checkbox hack) -->
  <input type="checkbox" id="nav-toggle" class="hidden peer" aria-hidden="true" />
  <div class="hidden peer-checked:block md:hidden border-t border-border bg-bg/95 backdrop-blur-md">
    <div class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-4">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'text-sm font-body transition-colors py-1',
            isActive(link.href)
              ? 'text-accent font-semibold'
              : 'text-text-muted hover:text-text',
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://github.com/devness-com/coverit"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-text-muted hover:text-text transition-colors py-1 flex items-center gap-2"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
        </svg>
        GitHub
      </a>
    </div>
  </div>
</nav>
