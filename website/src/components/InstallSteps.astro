---
const methods = [
  {
    number: 1,
    title: 'Claude Code',
    subtitle: 'Plugin with MCP tools + slash commands',
    lines: [
      '/plugin marketplace add devness-com/coverit',
      '/plugin install coverit@coverit',
    ],
  },
  {
    number: 2,
    title: 'Other AI Tools',
    subtitle: 'Cursor, Windsurf, VS Code, Gemini CLI, Zed, Cline, and more',
    lines: ['npx @devness/coverit'],
  },
  {
    number: 3,
    title: 'CLI',
    subtitle: 'Use directly in any project — no MCP required',
    lines: [
      'npx @devness/coverit scan      # Scan your codebase',
      'npx @devness/coverit cover     # Generate tests for gaps',
      'npx @devness/coverit run       # Run tests, fix failures',
      'npx @devness/coverit status    # See your score',
    ],
  },
];
---

<section class="animate-on-scroll">
  <div class="mx-auto max-w-[800px] px-6 py-24 md:py-32">
    <!-- Heading -->
    <h2 class="font-heading font-bold text-3xl md:text-4xl text-text text-center mb-4">
      Three Ways to Install
    </h2>
    <p class="font-body text-text-muted text-center mb-16 max-w-lg mx-auto">
      Choose the path that fits your workflow.
    </p>

    <!-- Methods -->
    <div class="relative ml-5 md:ml-10 mb-16">
      {methods.map((method, i) => (
        <div class="relative flex items-start gap-5 pb-10 last:pb-0">
          {/* Vertical connecting line */}
          {i < methods.length - 1 && (
            <div class="absolute left-5 top-10 bottom-0 w-px bg-border" />
          )}

          {/* Number badge */}
          <div class="relative z-10 flex-shrink-0 flex items-center justify-center w-10 h-10 rounded-full bg-accent text-[#faf7f2] font-heading font-bold text-base">
            {method.number}
          </div>

          {/* Method content */}
          <div class="pt-1.5 flex-1">
            <h3 class="font-heading font-semibold text-lg text-text mb-1">
              {method.title}
            </h3>
            <p class="font-body text-sm text-text-muted mb-3">{method.subtitle}</p>
            <div class="bg-bg-code rounded-lg px-4 py-3 space-y-1">
              {method.lines.map((line) => (
                <code class="block font-mono text-sm text-[#f5f0e8]">{line}</code>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
