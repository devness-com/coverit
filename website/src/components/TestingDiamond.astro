---
const layers = [
  { id: 'e2e', name: 'E2E', height: 10, color: '#FF8A65', description: 'Critical user paths' },
  { id: 'api', name: 'API', height: 15, color: '#FFB74D', description: 'Contract validation' },
  { id: 'integration', name: 'Integration', height: 50, color: '#FF7043', description: 'Business logic boundaries' },
  { id: 'unit', name: 'Unit', height: 20, color: '#FFB74D', description: 'Low-level logic' },
  { id: 'contract', name: 'Contract', height: 5, color: '#A1887F', description: 'Provider agreements' }
];

// Polygon shapes for each layer to form a perfect diamond
const clipPaths = {
  e2e: 'polygon(50% 0%, 50% 0%, 65% 100%, 35% 100%)',
  api: 'polygon(35% 0%, 65% 0%, 85% 100%, 15% 100%)',
  integration: 'polygon(15% 0%, 85% 0%, 100% 50%, 85% 100%, 15% 100%, 0% 50%)',
  unit: 'polygon(15% 0%, 85% 0%, 65% 100%, 35% 100%)',
  contract: 'polygon(35% 0%, 65% 0%, 50% 100%, 50% 100%)'
};
---

<div class="testing-diamond-container flex flex-col items-center py-4 px-2 overflow-visible relative group/container">
  <!-- Decorative background elements - scaled down -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] bg-accent/10 rounded-full blur-[100px] pointer-events-none opacity-50"></div>

  <div class="relative z-10 text-center mb-10 max-w-sm">
    <h3 class="font-heading font-black text-3xl md:text-4xl text-text mb-3 tracking-tight leading-tight">
      The Testing <span class="text-accent italic">Diamond</span>
    </h3>
    <p class="font-body text-base text-text-muted leading-relaxed">
      Modern systems thrive on <span class="text-text font-bold">Integration</span> — where the real complexity lives.
    </p>
  </div>

  <div class="relative w-full max-w-[320px] flex items-center justify-center">
    <!-- Central Diamond Stack -->
    <div class="relative h-[480px] w-full flex flex-col gap-[1px] perspective-1000 group">
      {layers.map((layer, i) => (
        <div 
          class="relative group/layer cursor-help transition-all duration-500 hover:scale-[1.05] hover:z-50"
          style={`height: ${layer.height}%;`}
        >
          <!-- Individual Clipped Layer -->
          <div 
            class="absolute inset-0 transition-all duration-300 shadow-lg overflow-hidden"
            style={`
              clip-path: ${clipPaths[layer.id]}; 
              background: linear-gradient(135deg, ${layer.color} 0%, color-mix(in srgb, ${layer.color}, black 20%) 100%);
            `}
          >
            <!-- Glossy Glass Effect -->
            <div class="absolute inset-0 bg-gradient-to-tr from-white/30 via-transparent to-transparent opacity-40"></div>
            
            <!-- Label Content (Percentage Only) -->
            <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none p-2 text-center">
               <span class="font-mono text-[14px] sm:text-base md:text-lg text-white font-black drop-shadow-md opacity-90 group-hover/layer:opacity-100 transition-opacity">
                 {layer.height}%
               </span>
            </div>
            
            <!-- Pulse Glow for Integration -->
            {layer.id === 'integration' && (
              <div class="absolute inset-0 bg-white/10 animate-pulse mix-blend-overlay"></div>
            )}
          </div>

          <!-- Tooltip (Visible on hover - shows name and description) -->
          <div class="absolute left-1/2 -translate-x-1/2 bottom-full mb-2 w-48 opacity-0 pointer-events-none group-hover/layer:opacity-100 group-hover/layer:pointer-events-auto transition-all duration-300 z-[100]">
             <div class="bg-bg-code/95 backdrop-blur-md p-3 rounded-xl shadow-2xl border border-border-strong/20 text-center">
                <p class="font-heading font-black text-accent text-[11px] uppercase tracking-wider mb-1">{layer.name}</p>
                <p class="font-body text-[11px] text-white/80 leading-relaxed">{layer.description}</p>
             </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="mt-12 px-6 py-2 bg-accent/5 rounded-full border border-accent/10">
    <p class="font-body text-[11px] text-accent italic opacity-90 text-center">
      "Integration tests are the highest signal in modern engineering."
    </p>
  </div>
</div>

<style>
  .perspective-1000 {
    perspective: 1000px;
  }
  
  .testing-diamond-container::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 50% 50%, var(--color-bg-warm), transparent 70%);
    z-index: -1;
    opacity: 0.5;
  }

  /* Floating animation for the diamond stack */
  .group\/container:hover .group {
    animation: float 4s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
</style>