---
const layers = [
  { name: 'E2E', percentage: '10%', color: 'var(--color-accent)', description: 'Critical user paths' },
  { name: 'API', percentage: '15%', color: 'var(--color-amber)', description: 'Contract validation' },
  { name: 'Integration', percentage: '50%', color: 'var(--color-accent-hover)', description: 'Business logic boundaries' },
  { name: 'Unit', percentage: '20%', color: 'var(--color-amber-dim)', description: 'Low-level implementation' },
  { name: 'Contract', percentage: '5%', color: 'var(--color-text-muted)', description: 'Provider agreements' }
];
---

<div class="testing-diamond flex flex-col items-center py-16 px-6 paper-card rounded-2xl overflow-visible">
  <h3 class="font-heading font-black text-2xl text-text mb-12 text-center">The Testing Diamond</h3>
  
  <div class="relative w-full max-w-[420px] h-[480px] flex flex-col justify-between gap-1 group">
    {layers.map((layer, i) => (
      <div 
        class="diamond-layer relative group/layer cursor-help transition-all duration-500 hover:scale-[1.02]"
        style={`height: ${layer.percentage};`}
      >
        <!-- Shape -->
        <div 
          class="absolute inset-0 transition-all duration-300 flex items-center justify-center overflow-hidden rounded-lg border border-white/20 shadow-lg"
          style={`background-color: ${layer.color}; opacity: ${0.7 + (i * 0.05)};`}
        >
          <!-- Layer Label -->
          <div class="relative z-10 flex flex-col items-center gap-0.5 pointer-events-none">
             <span class="font-heading font-black text-white text-xs md:text-sm tracking-widest">{layer.name}</span>
             <span class="font-mono text-[9px] md:text-[10px] text-white/70 font-bold">{layer.percentage}</span>
          </div>
          
          <!-- Glossy overlay -->
          <div class="absolute inset-0 bg-gradient-to-br from-white/10 to-transparent opacity-40"></div>
        </div>

        <!-- Tooltip (Positioned on the Left to avoid screen edge) -->
        <div class="absolute right-[calc(100%+1.5rem)] top-1/2 -translate-y-1/2 w-48 md:w-56 opacity-0 translate-x-4 pointer-events-none group-hover/layer:opacity-100 group-hover/layer:translate-x-0 transition-all duration-400 z-30">
           <div class="bg-bg-code/95 backdrop-blur-md p-4 md:p-5 rounded-2xl shadow-2xl border border-border-strong/20">
              <p class="font-heading font-black text-amber text-[10px] md:text-xs uppercase tracking-[0.2em] mb-2">{layer.name} Focus</p>
              <p class="font-body text-xs md:text-sm text-[#f5f0e8]/80 leading-relaxed font-medium">{layer.description}</p>
           </div>
           <!-- Connecting Arrow -->
           <div class="absolute top-1/2 -right-2 -translate-y-1/2 w-4 h-4 bg-bg-code/95 border-r border-b border-border-strong/20 rotate-[-45deg]"></div>
        </div>
      </div>
    ))}
  </div>

  <p class="font-body text-sm text-text-muted mt-12 text-center max-w-sm leading-relaxed italic opacity-80">
    "Focus on the boundaries where real bugs live."
  </p>
</div>

<style>
  .testing-diamond {
    background-image: radial-gradient(circle at top right, var(--color-bg-warm), transparent);
  }
  
  .diamond-layer:nth-child(1) { width: 35%; align-self: center; }
  .diamond-layer:nth-child(2) { width: 65%; align-self: center; }
  .diamond-layer:nth-child(3) { width: 95%; align-self: center; }
  .diamond-layer:nth-child(4) { width: 75%; align-self: center; }
  .diamond-layer:nth-child(5) { width: 45%; align-self: center; }
</style>