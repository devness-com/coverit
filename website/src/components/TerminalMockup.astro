---
interface Props {
  title?: string;
  initialContent?: string;
}

const { title = 'Terminal', initialContent = '' } = Astro.props;
---

<div class="terminal-mockup paper-card rounded-xl overflow-hidden shadow-editorial-lg border-border-strong group">
  <!-- Title bar -->
  <div class="flex items-center px-4 py-2.5 bg-bg-code/95 border-b border-border-strong/10">
    <div class="flex items-center gap-1.5">
      <span class="block w-2.5 h-2.5 rounded-full bg-[#ff5f57] shadow-sm"></span>
      <span class="block w-2.5 h-2.5 rounded-full bg-[#febc2e] shadow-sm"></span>
      <span class="block w-2.5 h-2.5 rounded-full bg-[#28c840] shadow-sm"></span>
    </div>
    <span class="flex-1 text-center font-mono text-[10px] text-text-muted/60 uppercase tracking-widest">{title}</span>
    <div class="w-[42px] flex justify-end">
       <span class="font-mono text-[10px] text-text-muted/40 group-hover:text-amber/40 transition-colors">bash</span>
    </div>
  </div>

  <!-- Content area -->
  <div class="p-6 font-mono text-[13px] leading-relaxed overflow-x-auto min-h-[250px] bg-bg-code selection:bg-amber/20">
    <div class="terminal-content whitespace-pre text-[#f5f0e8]" data-initial={initialContent}>
      <slot />
    </div>
  </div>
</div>

<style>
  .terminal-mockup {
    transform: perspective(1000px) rotateX(1deg);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .terminal-mockup:hover {
    transform: perspective(1000px) rotateX(0deg);
  }

  .terminal-content::after {
    content: '_';
    display: inline-block;
    width: 8px;
    background-color: var(--color-amber);
    animation: blink 1s step-end infinite;
    margin-left: 2px;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }
</style>

<script>
  class TerminalSimulator {
    el: HTMLElement;
    contentEl: HTMLElement;
    isTyping: boolean = false;

    constructor(el: HTMLElement) {
      this.el = el;
      this.contentEl = el.querySelector('.terminal-content') as HTMLElement;
      
      // Listen for custom command events
      window.addEventListener('coverit:terminal:run', (e: any) => {
        this.runCommand(e.detail.command, e.detail.output, e.detail.delay ?? 50);
      });
    }

    async runCommand(command: string, output: string[], speed: number = 30) {
      if (this.isTyping) return;
      this.isTyping = true;
      
      this.contentEl.innerHTML = '';
      
      // Type the command line
      const promptLine = document.createElement('div');
      promptLine.innerHTML = `<span class="text-amber/60">$</span> <span class="typing-cmd"></span>`;
      this.contentEl.appendChild(promptLine);
      const cmdSpan = promptLine.querySelector('.typing-cmd') as HTMLElement;
      
      for (const char of `coverit ${command}`) {
        cmdSpan.textContent += char;
        await this.wait(speed * 2);
      }

      await this.wait(300);

      // Show output lines
      for (const line of output) {
        const lineEl = document.createElement('div');
        lineEl.className = 'opacity-0 translate-y-1 transition-all duration-300';
        lineEl.innerHTML = line;
        this.contentEl.appendChild(lineEl);
        
        // Trigger reflow then animate
        lineEl.offsetHeight; 
        lineEl.classList.remove('opacity-0', 'translate-y-1');
        
        await this.wait(speed);
      }
      
      this.isTyping = false;
    }

    wait(ms: number) {
      return new Promise(resolve => setTimeout(resolve, ms));
    }
  }

  document.querySelectorAll<HTMLElement>('.terminal-mockup').forEach(el => {
    new TerminalSimulator(el);
  });
</script>
