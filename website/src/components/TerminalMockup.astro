---
interface Props {
  title?: string;
}

const { title = 'Terminal' } = Astro.props;
---

<div class="bg-bg-code rounded-xl overflow-hidden shadow-lg">
  <!-- Title bar -->
  <div class="flex items-center px-4 py-3 bg-[#2a2520]">
    <div class="flex items-center gap-2">
      <span class="block w-3 h-3 rounded-full bg-[#ff5f57]"></span>
      <span class="block w-3 h-3 rounded-full bg-[#febc2e]"></span>
      <span class="block w-3 h-3 rounded-full bg-[#28c840]"></span>
    </div>
    <span class="flex-1 text-center font-mono text-xs text-[#7a6e5f]">{title}</span>
    <!-- Spacer to balance the dots on the left -->
    <div class="w-[52px]"></div>
  </div>

  <!-- Content area -->
  <div class="p-5 font-mono text-sm leading-relaxed overflow-x-auto">
    <slot />
  </div>
</div>
