{
  "name": "coverit",
  "version": "0.1.0",
  "description": "AI-powered test generation and execution platform. Analyze features, generate tests, run them — one command.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "coverit": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "bun run dist/index.js",
    "cli": "bun run src/cli/index.ts",
    "mcp": "bun run src/mcp/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "ts-morph": "^25.0.0",
    "commander": "^13.1.0",
    "chalk": "^5.4.1",
    "ora": "^8.2.0",
    "zod": "^3.24.2",
    "simple-git": "^3.27.0",
    "glob": "^11.0.1",
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "@types/bun": "^1.2.4",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5",
    "eslint": "^9.20.0",
    "prettier": "^3.5.1"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "license": "MIT"
}
